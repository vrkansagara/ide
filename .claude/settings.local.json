{
  "permissions": {
    "allow": [
      "Bash(ls:./*)",
      "Bash(cat:./*)",
      "Bash(grep:./*)",
      "Bash(find:./*)",
      "Bash(ps:*)",
      "Bash(top:*)",
      "Bash(htop:*)",
      "Bash(git:./*)",
      "Bash(ls:*)",
      "Bash(chmod 511:*)",
      "Bash(bash:*)",
      "Bash(vim:*)",
      "Bash(git:*)",
      "Bash(grep:*)",
      "Bash(shellcheck:*)",
      "Bash(chmod +x:*)"
    ],
    "deny": [
      "Bash(rm:*)",
      "Bash(dd:*)",
      "Bash(mkfs:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(poweroff:*)",
      "Bash(chmod:777*)",
      "Bash(chown:root*)",
      "Bash(curl:*)",
      "Bash(wget:*)"
    ]
  },
  "sandbox": {
    "enabled": true,
    "network_access": false,
    "file_system": {
      "mode": "restricted",
      "allowed_paths": [
        "./"
      ]
    }
  },
  "telemetry": {
    "enabled": false
  },
  "logging": {
    "level": "error",
    "audit": true
  }
}
